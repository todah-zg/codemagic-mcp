{
  "name": "codemagic-mcp-server",
  "version": "1.0.5",
  "description": "MCP server for Codemagic CI/CD and App Store Connect / Google Play — build, sign, and publish mobile apps through AI agents",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "codemagic",
    "ci-cd",
    "mobile",
    "ios",
    "android",
    "flutter",
    "react-native",
    "app-store",
    "app-store-connect",
    "google-play",
    "testflight",
    "ai-agent",
    "claude"
  ],
  "license": "MIT",
  "author": "Codemagic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/todah-zg/codemagic-mcp.git"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "codemagic-mcp": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist/"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.0.0",
    "js-yaml": "^4.2.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  }
}
